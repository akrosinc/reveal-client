<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_marginStart="@dimen/register_list_item_margin"
    android:layout_marginEnd="@dimen/register_list_item_end_margin"
    android:background="@color/white"
    android:paddingTop="@dimen/register_list_max_padding"
    android:paddingBottom="@dimen/register_list_max_padding"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:layout_marginBottom="5dp"
    card_view:cardCornerRadius="10dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/event_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="@string/event_date"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />

        <TextView
            android:id="@+id/event_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:visibility="gone"
            android:textSize="@dimen/structure_info_card_text_size" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/event_type_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/event_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="@string/form_name"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />

        <TextView
            android:id="@+id/event_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/event_sop_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="@string/sop"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />

        <TextView
            android:id="@+id/sop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginLeft="20dp"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/event_entity_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="@string/hh_village_name"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />

        <TextView
            android:id="@+id/entity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/event_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="@string/status"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/data_collection_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:text="@string/data_collection_date"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />

        <TextView
            android:id="@+id/data_collection_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:gravity="center_vertical"
            android:textAllCaps="false"
            android:textColor="@color/text_black"
            android:textSize="@dimen/structure_info_card_text_size" />
    </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

